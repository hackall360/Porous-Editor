{
  "name": "porous-editor",
  "version": "1.0.0",
  "description": "Porous Editor - A fully featured save editor for multiple game save formats",
  "scripts": {
    "dev": "npm run build:watch",
    "build": "npm run build:client",
    "build:client": "esbuild src/client/main.ts --bundle --outfile=public/js/bundle.js --minify --sourcemap --loader:.js=js --loader:.ts=ts",
    "build:watch": "esbuild src/client/main.ts --bundle --outfile=public/js/bundle.js --sourcemap --loader:.js=js --loader:.ts=ts --watch",
    "lint": "eslint src/**/*.{ts,tsx}",
    "typecheck": "tsc --noEmit",
    "serve": "npx serve -s public -l 3000"
  },
  "keywords": [
    "save-editor",
    "game-saves",
    "rpg-maker",
    "unity",
    "typescript",
    "client-side",
    "porous-editor"
  ],
  "author": "Porous Editor Team",
  "license": "MPL-2.0",
  "dependencies": {
    "pako": "^2.1.0",
    "lz-string": "^1.5.0",
    "fflate": "^0.8.2",
    "plist": "^3.1.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.1.0",
    "@typescript-eslint/parser": "^6.1.0",
    "esbuild": "^0.18.11",
    "eslint": "^8.45.0",
    "typescript": "^5.1.6"
  }
}
